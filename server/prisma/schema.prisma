generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
  blocked
}

enum UserRole {
  admin_owner
  barber
  client
}

enum AppointmentStatus {
  scheduled
  confirmed
  cancelled
  no_show
  completed
}

enum PaymentStatus {
  pending
  paid
  refunded
}

enum InventoryMovementType {
  in
  out
  adjustment
}

model User {
  id           String     @id @default(uuid()) @db.VarChar(36)
  email        String     @unique @db.VarChar(150)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  status       UserStatus @default(active)
  role         UserRole
  createdAt    DateTime   @default(now()) @map("created_at")

  barberProfile BarberProfile?
  refreshTokens RefreshToken[]

  @@map("users")
}

model Client {
  id        String   @id @default(uuid()) @db.VarChar(36)
  name      String   @db.VarChar(100)
  phone     String   @unique @db.VarChar(20)
  email     String?  @db.VarChar(150)
  createdAt DateTime @default(now()) @map("created_at")

  appointments       Appointment[]
  aestheticHistories AestheticHistory[]

  @@map("clients")
}

model BarberProfile {
  id                   String   @id @default(uuid()) @db.VarChar(36)
  userId               String   @unique @map("user_id") @db.VarChar(36)
  name                 String   @db.VarChar(100)
  commissionPercentage Decimal  @map("commission_percentage") @db.Decimal(5, 2)
  createdAt            DateTime @default(now()) @map("created_at")

  user               User               @relation(fields: [userId], references: [id])
  appointments       Appointment[]
  aestheticHistories AestheticHistory[]
  commissions        Commission[]
  payments           Payment[]

  @@map("barber_profiles")
}

model Service {
  id              String   @id @default(uuid()) @db.VarChar(36)
  name            String   @db.VarChar(100)
  price           Decimal  @db.Decimal(10, 2)
  durationMinutes Int      @map("duration_minutes")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  appointmentServices AppointmentService[]

  @@map("services")
}

model Appointment {
  id              String            @id @default(uuid()) @db.VarChar(36)
  clientId        String            @map("client_id") @db.VarChar(36)
  barberId        String            @map("barber_id") @db.VarChar(36)
  appointmentDate DateTime          @map("appointment_date")
  status          AppointmentStatus @default(scheduled)
  notes           String?           @db.Text
  createdAt       DateTime          @default(now()) @map("created_at")

  client     Client               @relation(fields: [clientId], references: [id])
  barber     BarberProfile        @relation(fields: [barberId], references: [id])
  services   AppointmentService[]
  payment    Payment?
  commission Commission?

  @@map("appointments")
}

model AppointmentService {
  id            String  @id @default(uuid()) @db.VarChar(36)
  appointmentId String  @map("appointment_id") @db.VarChar(36)
  serviceId     String  @map("service_id") @db.VarChar(36)
  priceApplied  Decimal @map("price_applied") @db.Decimal(10, 2)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id])

  @@unique([appointmentId, serviceId])
  @@map("appointment_services")
}

model AestheticHistory {
  id        String   @id @default(uuid()) @db.VarChar(36)
  clientId  String   @map("client_id") @db.VarChar(36)
  barberId  String   @map("barber_id") @db.VarChar(36)
  notes     String   @db.Text
  photoUrl  String?  @map("photo_url") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  client Client        @relation(fields: [clientId], references: [id])
  barber BarberProfile @relation(fields: [barberId], references: [id])

  @@map("aesthetic_histories")
}

model Product {
  id            String   @id @default(uuid()) @db.VarChar(36)
  name          String   @db.VarChar(100)
  stock         Int      @default(0)
  criticalLimit Int      @default(5) @map("critical_limit")
  price         Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  inventoryMovements InventoryMovement[]

  @@map("products")
}

model InventoryMovement {
  id        String                @id @default(uuid()) @db.VarChar(36)
  productId String                @map("product_id") @db.VarChar(36)
  type      InventoryMovementType
  quantity  Int
  reason    String?               @db.VarChar(255)
  createdAt DateTime              @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@map("inventory_movements")
}

model Payment {
  id            String        @id @default(uuid()) @db.VarChar(36)
  appointmentId String        @unique @map("appointment_id") @db.VarChar(36)
  barberId      String        @map("barber_id") @db.VarChar(36)
  amount        Decimal       @db.Decimal(10, 2)
  status        PaymentStatus @default(pending)
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  appointment Appointment   @relation(fields: [appointmentId], references: [id])
  barber      BarberProfile @relation(fields: [barberId], references: [id])
  commission  Commission?

  @@map("payments")
}

model Commission {
  id               String   @id @default(uuid()) @db.VarChar(36)
  appointmentId    String   @unique @map("appointment_id") @db.VarChar(36)
  barberId         String   @map("barber_id") @db.VarChar(36)
  paymentId        String   @unique @map("payment_id") @db.VarChar(36)
  serviceAmount    Decimal  @map("service_amount") @db.Decimal(10, 2)
  commissionRate   Decimal  @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal  @map("commission_amount") @db.Decimal(10, 2)
  calculatedAt     DateTime @default(now()) @map("calculated_at")

  appointment Appointment   @relation(fields: [appointmentId], references: [id])
  barber      BarberProfile @relation(fields: [barberId], references: [id])
  payment     Payment       @relation(fields: [paymentId], references: [id])

  @@map("commissions")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
